package forward;

import com.ftn.sbnz.model.models.VehicleProfile;
import com.ftn.sbnz.model.models.DtcCode;
import com.ftn.sbnz.model.models.DiagnosticResult;
import com.ftn.sbnz.model.models.TuningAction;
import com.ftn.sbnz.model.models.ToolRecommendation;
import com.ftn.sbnz.model.enums.ComponentStatus;
import com.ftn.sbnz.model.enums.EcuType;

// =============================================================================
// NIVO 1: DTC kod → status komponente
// Svaki DTC kod (greska koju auto prijavljuje) mapira se na status komponente.
// =============================================================================

rule "DTC P0401 - EGR nedovoljan protok -> EGR zapusen"
    salience 100
    when
        $dtc : DtcCode(code == "P0401", $vid : vehicleId)
        not DiagnosticResult(vehicleId == $vid, componentStatus == ComponentStatus.EGR_CLOGGED)
    then
        insert(new DiagnosticResult(ComponentStatus.EGR_CLOGGED, $vid));
        System.out.println("[Nivo 1] Vozilo " + $vid + ": DTC P0401 -> EGR ZAPUSEN");
end

rule "DTC P0402 - EGR preveliki protok -> EGR prekoracenje"
    salience 100
    when
        $dtc : DtcCode(code == "P0402", $vid : vehicleId)
        not DiagnosticResult(vehicleId == $vid, componentStatus == ComponentStatus.EGR_EXCESSIVE_FLOW)
    then
        insert(new DiagnosticResult(ComponentStatus.EGR_EXCESSIVE_FLOW, $vid));
        System.out.println("[Nivo 1] Vozilo " + $vid + ": DTC P0402 -> EGR PREKORACENJE PROTOKA");
end

rule "DTC P242F - DPF preopterecen pepelom"
    salience 100
    when
        $dtc : DtcCode(code == "P242F", $vid : vehicleId)
        not DiagnosticResult(vehicleId == $vid, componentStatus == ComponentStatus.DPF_ASH_OVERLOADED)
    then
        insert(new DiagnosticResult(ComponentStatus.DPF_ASH_OVERLOADED, $vid));
        System.out.println("[Nivo 1] Vozilo " + $vid + ": DTC P242F -> DPF PREOPTERECEN PEPELOM");
end

rule "DTC P2002 - DPF niska efikasnost"
    salience 100
    when
        $dtc : DtcCode(code == "P2002", $vid : vehicleId)
        not DiagnosticResult(vehicleId == $vid, componentStatus == ComponentStatus.DPF_LOW_EFFICIENCY)
    then
        insert(new DiagnosticResult(ComponentStatus.DPF_LOW_EFFICIENCY, $vid));
        System.out.println("[Nivo 1] Vozilo " + $vid + ": DTC P2002 -> DPF NISKA EFIKASNOST");
end

// =============================================================================
// NIVO 2: Status komponente + podaci o vozilu → preporucena akcija
// VehicleProfile se vezuje za konkretno vozilo pomocu vehicleId.
// =============================================================================

rule "EGR zapusen + kilometraza > 150000 -> preporuci EGR OFF"
    salience 80
    when
        DiagnosticResult(componentStatus == ComponentStatus.EGR_CLOGGED, $vid : vehicleId)
        VehicleProfile(vehicleId == $vid, mileage > 150000)
        not TuningAction(vehicleId == $vid, actionType == "EGR_OFF_RECOMMENDED")
    then
        insert(new TuningAction(
            "EGR_OFF_RECOMMENDED",
            "Preporuceno softversko gasenje EGR ventila. Kilometraza > 150.000 km, ventil je istroson.",
            $vid
        ));
        System.out.println("[Nivo 2] Vozilo " + $vid + ": Preporuceno EGR OFF (km > 150000)");
end

rule "EGR zapusen + kilometraza <= 150000 -> preporuci ciscenje EGR"
    salience 80
    when
        DiagnosticResult(componentStatus == ComponentStatus.EGR_CLOGGED, $vid : vehicleId)
        VehicleProfile(vehicleId == $vid, mileage <= 150000)
        not TuningAction(vehicleId == $vid, actionType == "EGR_CLEAN_RECOMMENDED")
    then
        insert(new TuningAction(
            "EGR_CLEAN_RECOMMENDED",
            "Preporuceno mehanicko ciscenje EGR ventila. Kilometraza je ispod 150.000 km.",
            $vid
        ));
        System.out.println("[Nivo 2] Vozilo " + $vid + ": Preporuceno ciscenje EGR (km <= 150000)");
end

rule "DPF preopterecen pepelom -> preporuci DPF OFF"
    salience 80
    when
        DiagnosticResult(componentStatus == ComponentStatus.DPF_ASH_OVERLOADED, $vid : vehicleId)
        not TuningAction(vehicleId == $vid, actionType == "DPF_OFF_RECOMMENDED")
    then
        insert(new TuningAction(
            "DPF_OFF_RECOMMENDED",
            "Preporuceno mehanicko vadjenje i softversko gasenje DPF filtera. Filter je preopterecen pepelom.",
            $vid
        ));
        System.out.println("[Nivo 2] Vozilo " + $vid + ": Preporuceno DPF OFF");
end

rule "DPF niska efikasnost -> preporuci regeneraciju"
    salience 80
    when
        DiagnosticResult(componentStatus == ComponentStatus.DPF_LOW_EFFICIENCY, $vid : vehicleId)
        not TuningAction(vehicleId == $vid, actionType == "DPF_REGENERATION_RECOMMENDED")
    then
        insert(new TuningAction(
            "DPF_REGENERATION_RECOMMENDED",
            "Preporucena prisilna regeneracija DPF filtera pre donosenja odluke o gasenju.",
            $vid
        ));
        System.out.println("[Nivo 2] Vozilo " + $vid + ": Preporucena DPF regeneracija");
end

rule "EGR prekoracenje protoka -> preporuci zamenu EGR"
    salience 80
    when
        DiagnosticResult(componentStatus == ComponentStatus.EGR_EXCESSIVE_FLOW, $vid : vehicleId)
        not TuningAction(vehicleId == $vid, actionType == "EGR_REPLACE_RECOMMENDED")
    then
        insert(new TuningAction(
            "EGR_REPLACE_RECOMMENDED",
            "EGR ventil propusta previse gasova - preporucena zamena ili softversko gasenje. Ciscenje nece pomoci.",
            $vid
        ));
        System.out.println("[Nivo 2] Vozilo " + $vid + ": Preporucena zamena/gasenje EGR (prekoracenje protoka)");
end

// =============================================================================
// NIVO 3: Preporucena akcija + ECU tip → preporuceni alat
// actionType dodat u ToolRecommendation radi sprecavanja kolizije kada isti
// alat treba biti preporucen i za EGR OFF i za DPF OFF na istom vozilu
// =============================================================================

rule "EGR OFF + EDC16 -> KESSv2 via OBD"
    salience 60
    when
        TuningAction(actionType == "EGR_OFF_RECOMMENDED", $vid : vehicleId)
        VehicleProfile(vehicleId == $vid, ecuType == EcuType.BOSCH_EDC16)
        not ToolRecommendation(vehicleId == $vid, actionType == "EGR_OFF_RECOMMENDED", toolName == "KESSv2")
    then
        insert(new ToolRecommendation(
            "EGR_OFF_RECOMMENDED",
            "KESSv2",
            "OBD port (in-car)",
            "Koristiti KESSv2 protokol za Bosch EDC16. Citanje i upis fajla direktno kroz OBD prikljucak bez skidanja racunara",
            $vid
        ));
        System.out.println("[Nivo 3] Vozilo " + $vid + ": Alat -> KESSv2 via OBD (EDC16, EGR OFF)");
end

rule "EGR OFF + EDC17 -> PCMflash Bench mode"
    salience 60
    when
        TuningAction(actionType == "EGR_OFF_RECOMMENDED", $vid : vehicleId)
        VehicleProfile(vehicleId == $vid, ecuType == EcuType.BOSCH_EDC17)
        not ToolRecommendation(vehicleId == $vid, actionType == "EGR_OFF_RECOMMENDED", toolName == "PCMflash")
    then
        insert(new ToolRecommendation(
            "EGR_OFF_RECOMMENDED",
            "PCMflash",
            "Bench mode (racunar skinut iz vozila)",
            "EDC17 zahteva Bench mode - racunar se fizicki skida i spaja direktno. Alternativa: Flex tool",
            $vid
        ));
        System.out.println("[Nivo 3] Vozilo " + $vid + ": Alat -> PCMflash Bench mode (EDC17, EGR OFF)");
end

