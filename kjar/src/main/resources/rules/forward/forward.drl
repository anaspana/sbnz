rule "DPF OFF + BMW -> daVinci softver"
    salience 60
    when
        TuningAction(actionType == "DPF_OFF_RECOMMENDED", $vid : vehicleId)
        VehicleProfile(vehicleId == $vid, vehicleBrand == "BMW")
        not ToolRecommendation(vehicleId == $vid, actionType == "DPF_OFF_RECOMMENDED", toolName == "daVinci")
    then
        insert(new ToolRecommendation(
            "DPF_OFF_RECOMMENDED",
            "daVinci",
            "Software file editing",
            "Za BMW DPF OFF koristiti daVinci softver za obradu ECU fajla. Preporuceno uz WinOLS za proveru mapa.",
            $vid
        ));
        System.out.println("[Nivo 3] Vozilo " + $vid + ": Alat -> daVinci (BMW, DPF OFF)");
end

rule "DPF OFF + EDC17 nije BMW -> PCMflash Bench mode"
    salience 60
    when
        TuningAction(actionType == "DPF_OFF_RECOMMENDED", $vid : vehicleId)
        VehicleProfile(vehicleId == $vid, ecuType == EcuType.BOSCH_EDC17, vehicleBrand != "BMW")
        not ToolRecommendation(vehicleId == $vid, actionType == "DPF_OFF_RECOMMENDED", toolName == "PCMflash")
    then
        insert(new ToolRecommendation(
            "DPF_OFF_RECOMMENDED",
            "PCMflash",
            "Bench mode",
            "EDC17 DPF OFF zahteva Bench mode. Koristiti PCMflash modul za odgovarajuci model vozila.",
            $vid
        ));
        System.out.println("[Nivo 3] Vozilo " + $vid + ": Alat -> PCMflash Bench mode (EDC17, DPF OFF)");
end

